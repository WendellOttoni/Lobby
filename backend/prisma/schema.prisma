generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  statusText   String?  @db.VarChar(128)

  ownedServers      Server[]          @relation("ServerOwner")
  serverMemberships ServerMember[]
  roomMemberships   RoomMember[]
  messages          Message[]
  reactions         MessageReaction[]
  pins              MessagePin[]
}

model Server {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  ownerId    String
  createdAt  DateTime @default(now())

  owner    User           @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  ServerMember[]
  rooms    Room[]
  channels TextChannel[]
  messages Message[]
}

model ServerMember {
  id         String   @id @default(cuid())
  userId     String
  serverId   String
  role       String   @default("member")
  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
}

model Room {
  id        String   @id @default(cuid())
  name      String
  serverId  String
  createdAt DateTime @default(now())

  server  Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members RoomMember[]
}

model RoomMember {
  id       String   @id @default(cuid())
  userId   String
  roomId   String
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
}

model TextChannel {
  id        String   @id @default(cuid())
  name      String
  serverId  String
  createdAt DateTime @default(now())

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([serverId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessagePin {
  id        String   @id @default(cuid())
  messageId String   @unique
  serverId  String
  channelId String?
  pinnedBy  String
  pinnedAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinner  User    @relation(fields: [pinnedBy], references: [id], onDelete: Cascade)

  @@index([serverId])
}

model Message {
  id          String    @id @default(cuid())
  content     String    @db.VarChar(2000)
  createdAt   DateTime  @default(now())
  editedAt    DateTime?
  authorId    String
  serverId    String
  channelId   String?
  replyToId   String?

  author      User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  server      Server            @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channel     TextChannel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  replyTo     Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     Message[]         @relation("MessageReplies")
  reactions   MessageReaction[]
  pin         MessagePin?

  @@index([serverId, createdAt])
  @@index([channelId, createdAt])
}
