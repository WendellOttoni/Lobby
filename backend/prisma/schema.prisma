generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  statusText   String?  @db.VarChar(128)
  avatarUrl    String?  @db.VarChar(512)

  ownedServers           Server[]             @relation("ServerOwner")
  serverMemberships      ServerMember[]
  serverBans             ServerBan[]          @relation("ServerBannedUser")
  issuedServerBans       ServerBan[]          @relation("ServerBanActor")
  serverAuditLogs        ServerAuditLog[]     @relation("ServerAuditActor")
  roomMemberships        RoomMember[]
  messages               Message[]
  reactions              MessageReaction[]
  pins                   MessagePin[]
  channelReads           ChannelRead[]
  notificationPreferences NotificationPreference[]
  sentFriendRequests     Friendship[]         @relation("FriendRequests")
  receivedFriendRequests Friendship[]         @relation("FriendResponses")
  dmConversations1       DirectConversation[] @relation("DMUser1")
  dmConversations2       DirectConversation[] @relation("DMUser2")
  directMessages         DirectMessage[]      @relation("DMAuthor")
}

model Server {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique
  inviteUses Int      @default(0)
  inviteMaxUses Int?
  inviteExpiresAt DateTime?
  ownerId    String
  createdAt  DateTime @default(now())

  owner      User           @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members    ServerMember[]
  bans       ServerBan[]
  auditLogs  ServerAuditLog[]
  notificationPreferences NotificationPreference[]
  rooms      Room[]
  channels   TextChannel[]
  messages   Message[]
  categories Category[]
  channelPermissions ChannelPermission[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(64)
  serverId  String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  server   Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channels TextChannel[]
  rooms    Room[]

  @@index([serverId])
}

model ServerMember {
  id         String   @id @default(cuid())
  userId     String
  serverId   String
  role       String   @default("member")
  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
}

model ServerBan {
  id        String   @id @default(cuid())
  userId    String
  serverId  String
  bannedBy  String
  reason    String?  @db.VarChar(256)
  createdAt DateTime @default(now())

  user   User   @relation("ServerBannedUser", fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  banner User   @relation("ServerBanActor", fields: [bannedBy], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
  @@index([serverId])
}

model ServerAuditLog {
  id         String   @id @default(cuid())
  serverId   String
  actorId    String
  action     String   @db.VarChar(64)
  targetId   String?  @db.VarChar(128)
  targetType String?  @db.VarChar(64)
  metadata   Json?
  createdAt  DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  actor  User   @relation("ServerAuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
  @@index([actorId])
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  serverId  String
  scopeKey  String   @db.VarChar(160)
  channelId String?
  muted     Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId, scopeKey])
  @@index([serverId])
}

model Room {
  id         String   @id @default(cuid())
  name       String
  serverId   String
  categoryId String?
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  server   Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  category Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  members  RoomMember[]

  @@index([categoryId])
}

model RoomMember {
  id       String   @id @default(cuid())
  userId   String
  roomId   String
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
}

model TextChannel {
  id         String   @id @default(cuid())
  name       String
  serverId   String
  categoryId String?
  position   Int      @default(0)
  createdAt  DateTime @default(now())

  server   Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  category Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  messages Message[]
  reads    ChannelRead[]
  permissions ChannelPermission[]

  @@index([serverId])
  @@index([categoryId])
}

model ChannelPermission {
  id        String   @id @default(cuid())
  serverId  String
  channelId String
  role      String   @db.VarChar(32)
  canRead   Boolean  @default(true)
  canWrite  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  server  Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channel TextChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, role])
  @@index([serverId])
}

model ChannelRead {
  id         String   @id @default(cuid())
  userId     String
  channelId  String
  lastReadAt DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel TextChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String   @db.VarChar(16)
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model MessagePin {
  id        String   @id @default(cuid())
  messageId String   @unique
  serverId  String
  channelId String?
  pinnedBy  String
  pinnedAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinner  User    @relation(fields: [pinnedBy], references: [id], onDelete: Cascade)

  @@index([serverId])
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  requester User @relation("FriendRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendResponses", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId])
}

model DirectConversation {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())

  user1    User            @relation("DMUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User            @relation("DMUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@unique([user1Id, user2Id])
}

model DirectMessage {
  id             String   @id @default(cuid())
  content        String   @db.VarChar(2000)
  createdAt      DateTime @default(now())
  editedAt       DateTime?
  authorId       String
  conversationId String

  author       User               @relation("DMAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Message {
  id          String    @id @default(cuid())
  content     String    @db.VarChar(2000)
  createdAt   DateTime  @default(now())
  editedAt    DateTime?
  authorId    String
  serverId    String
  channelId   String?
  replyToId   String?

  author      User                @relation(fields: [authorId], references: [id], onDelete: Cascade)
  server      Server              @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channel     TextChannel?        @relation(fields: [channelId], references: [id], onDelete: SetNull)
  replyTo     Message?            @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies     Message[]           @relation("MessageReplies")
  reactions   MessageReaction[]
  pin         MessagePin?
  attachments MessageAttachment[]

  @@index([serverId, createdAt])
  @@index([channelId, createdAt])
}

model MessageAttachment {
  id        String @id @default(cuid())
  messageId String
  filename  String
  url       String
  mimeType  String
  size      Int

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}
