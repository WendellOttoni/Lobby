{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lobby",
  "version": "0.1.0",
  "identifier": "com.lobby.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lobby",
        "width": 900,
        "height": 700,
        "minWidth": 500,
        "minHeight": 400,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: https:; connect-src 'self' https: wss:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
