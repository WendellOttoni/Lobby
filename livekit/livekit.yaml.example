# LiveKit Server — configuração local de desenvolvimento
# Baixe o binário em: https://github.com/livekit/livekit/releases
# Execute com: livekit-server --config livekit.yaml

port: 7880
rtc:
  tcp_port: 7881
  port_range_start: 50000
  port_range_end: 60000

keys:
  # Gere suas chaves com: ./livekit-server.exe generate-keys
  # Copie para livekit.yaml (sem .example) e para backend/.env
  SUA_API_KEY: SEU_API_SECRET

logging:
  level: info

development: true
